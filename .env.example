# Copy this file to .env and fill in the values
# NEVER commit .env to source control

# PostgreSQL connection string (local dev format)
DATABASE_URL=Host=localhost;Port=5432;Database=HospitalDB;Username=postgres;Password=yourpassword

# JWT signing secret - must be at least 32 characters
# Generate one with: openssl rand -base64 48
JWT_SECRET=your-very-long-secret-key-at-least-32-characters-here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5001,http://192.168.11.163:5001

# ASP.NET Core environment (Development | Production)
ASPNETCORE_ENVIRONMENT=Development
